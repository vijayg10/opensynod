# Copy this file to .env and fill in your values

# Application
ENVIRONMENT=development
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/opensynod

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT — Generate with: openssl genrsa 4096 | openssl rsa -pubout
# Then paste the full PEM-encoded keys below (multiline, use \n or a file)
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# Development — set to true to mock all LLM calls with random text (no API keys needed)
MOCK_LLM_CALLS=false

# LLM Provider API Keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Search Provider
SEARCH_PROVIDER=tavily  # tavily | brave | bing | serper
TAVILY_API_KEY=
BRAVE_API_KEY=
SERPER_API_KEY=

# Vector Store
VECTOR_STORE=pgvector  # pgvector | qdrant | chroma

# Optional
HTTPS_PROXY=
